{
  "name": "Comment",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string"
    },
    "parent_comment_id": {
      "type": "string",
      "description": "For nested replies"
    },
    "content": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "author_id": {
      "type": "string",
      "description": "user.id of commenter"
    },
    "is_anonymous": {
      "type": "boolean",
      "default": false
    },
    "upvotes": {
      "type": "number",
      "default": 0
    },
    "report_count": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "flagged",
        "hidden",
        "removed"
      ],
      "default": "active"
    },
    "hidden_by": {
      "type": "string",
      "description": "admin user id who hid it"
    },
    "hidden_reason": {
      "type": "string"
    },
    "is_pending_review": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "post_id",
    "content"
  ]
}