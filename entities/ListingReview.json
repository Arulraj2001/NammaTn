{
  "name": "ListingReview",
  "type": "object",
  "properties": {
    "listing_id": {
      "type": "string"
    },
    "session_ref": {
      "type": "string"
    },
    "rating": {
      "type": "number"
    },
    "comment": {
      "type": "string"
    },
    "is_anonymous": {
      "type": "boolean",
      "default": true
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "removed"
      ],
      "default": "active"
    }
  },
  "required": [
    "listing_id",
    "session_ref",
    "rating"
  ]
}