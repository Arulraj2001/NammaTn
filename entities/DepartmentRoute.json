{
  "name": "DepartmentRoute",
  "type": "object",
  "properties": {
    "category_slug": {
      "type": "string",
      "description": "Category slug this route applies to"
    },
    "category_name": {
      "type": "string"
    },
    "department": {
      "type": "string",
      "description": "Responsible department name"
    },
    "office_type": {
      "type": "string"
    },
    "reason": {
      "type": "string",
      "description": "Why this department is responsible"
    },
    "official_website": {
      "type": "string"
    },
    "complaint_portal": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "complaint_template": {
      "type": "string",
      "description": "Template message (use [LOCATION], [TITLE], [DESCRIPTION], [RECEIPT_ID], [DATE] as placeholders)"
    },
    "instructions": {
      "type": "string"
    },
    "escalation_instructions": {
      "type": "string"
    },
    "follow_up_days": {
      "type": "number",
      "default": 14
    },
    "escalation_days": {
      "type": "number",
      "default": 30
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "category_slug",
    "department"
  ]
}